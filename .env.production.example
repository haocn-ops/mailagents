# Control plane
PORT=3000
JWT_SECRET=replace-with-long-random-secret
ADMIN_API_TOKEN=replace-with-long-random-admin-token
INTERNAL_API_TOKEN=replace-with-long-random-internal-token
BASE_CHAIN_ID=84532
MAILBOX_DOMAIN=inbox.mailagents.net
MAIL_PROVIDER=mailu
STORAGE_BACKEND=postgres
DATABASE_URL=postgres://user:pass@postgres.internal:5432/mailcloud
MAILU_BASE_URL=https://mailu.internal.mailagents.net
MAILU_API_TOKEN=replace-with-mailu-internal-token
MAILU_RELEASE_MODE=disable
MAILU_QUOTA_BYTES=1073741824
MAILU_AUTH_SCHEME=BEARER
WEBHOOK_SECRET_ENCRYPTION_KEY=replace-with-different-random-secret
WEBHOOK_TIMEOUT_MS=5000
WEBHOOK_RETRY_ATTEMPTS=3

# SIWE
SIWE_MODE=strict
SIWE_DOMAIN=api.mailagents.net
SIWE_URI=https://api.mailagents.net
SIWE_STATEMENT=Sign in to Agent Mail Cloud
SIWE_CHALLENGE_TTL_MS=300000

# x402
PAYMENT_MODE=hmac
X402_HMAC_SECRET=replace-with-random-payment-secret
X402_HMAC_SKEW_SEC=300

# Startup safety
NODE_ENV=production
ENFORCE_SAFE_STARTUP=true
REQUIRE_PROD_PREFLIGHT=true
